# Copy to .env, fill in, then: docker compose up -d --build
#
# Generate the two secrets (any Python with `cryptography` installed):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"                        # SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # CREDENTIALS_ENCRYPTION_KEY

# Signs JWTs. Changing it invalidates every existing login.
SECRET_KEY=

# Encrypts your stored provider/LLM API keys at rest (Fernet).
# CHANGING THIS MAKES ALREADY-STORED KEYS UNREADABLE — you'd have to re-enter them.
CREDENTIALS_ENCRYPTION_KEY=

# Postgres
POSTGRES_USER=ajh
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ajh

# Provider and LLM keys are NOT set here. Each user stores their own (Apify, Anthropic/
# OpenAI, SerpAPI, RapidAPI, Adzuna, Jooble, Telegram, SMTP) via the Settings screen;
# they're encrypted into the database with CREDENTIALS_ENCRYPTION_KEY.
