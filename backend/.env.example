# AJH backend environment — copy to .env and fill in
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-long-random-string
CREDENTIALS_ENCRYPTION_KEY=generate-a-fernet-key
DATABASE_URL=postgresql+asyncpg://ajh:ajh@localhost:5432/ajh
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Provider/LLM keys are NOT set here — each user stores their own keys
# (Apify, Anthropic/OpenAI, SerpAPI, RapidAPI, Adzuna, Jooble) encrypted in the DB via Settings UI.
